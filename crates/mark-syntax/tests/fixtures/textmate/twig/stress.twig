  <%# Ruby ERB bridge retained for the migration window. %>
  <% reports = ["daily", "weekly"].map { |name| name.upcase } %>
  <%= reports.join(", ") %>
  <?r puts "Nitro Ruby bridge closed" ?>
  <footer role="contentinfo">
    <small>{{ source('partials/legal.twig', ignore_missing = true)|default('No legal copy') }}</small>
    <time datetime="{{ 'now'|date('c') }}">{{ 'now'|date('Y-m-d H:i') }}</time>
  </footer>
</body>
</html>
