Depth: 1
Content-Type: application/xml

<propfind xmlns="DAV:">
  <prop><displayname/><getetag/><getcontentlength/></prop>
</propfind>

HTTP/1.1 207 Multi-Status
Content-Type: application/xml

<multistatus xmlns="DAV:">
  <response>
    <href>/team/roadmap-🗺️.md</href>
    <propstat><status>HTTP/1.1 200 OK</status></propstat>
  </response>
</multistatus>

