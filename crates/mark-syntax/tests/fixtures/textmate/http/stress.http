### Shared environment and authentication
# This file intentionally mixes requests, captured responses, and body languages.
@scheme = https
@host = api.example.test
@version = v2
@accountId = acct_東京_42
@token = demo-token-αβ
@uploadFile = ./fixtures/résumé-🚀.pdf

# @prompt traceId Optional distributed trace identifier
// @prompt region Deployment region, such as eu-west-1
# @note
// Variables above are safe fixture values, not working credentials.

### Shell-driven health probe
# @name curlHealth
curl --silent --show-error \
  --request GET \
  --header 'Accept: application/json' \
  --header "Authorization: Bearer ${DEMO_TOKEN:-fixture-token}" \
  "https://api.example.test/health?verbose=true" | jq '{status, version}'
### curl block closed

HTTP/1.1 200 OK
Content-Type: application/json
Cache-Control: no-store
X-Trace-Id: trace-curl-0001

{
  "status": "ok",
  "version": "2.7.0",
  "message": "ready ✓"
}

