### Create a project with nested JSON
# @name createProject
POST {{scheme}}://{{host}}/{{version}}/projects HTTP/1.1
Authorization: Bearer {{token}}
Content-Type: application/json
Idempotency-Key: fixture-create-001
X-Display-Name: naïve 🚀 client

{
  "name": "Aurora 𝄞",
  "description": "BMP: Ελληνικά; astral: 🛰️",
  "owner": {
    "account": "{{accountId}}",
    "contacts": [
      {"type": "email", "value": "ops@example.test"},
      {"type": "chat", "value": "#lancement"}
    ]
  },
  "settings": {
    "private": true,
    "retentionDays": 30,
    "threshold": 0.875,
    "callback": "https://hooks.example.test/project?source=http-fixture"
  }
}

HTTP/1.1 201 Created
Location: https://api.example.test/v2/projects/prj_9000
Content-Type: application/json

{"id":"prj_9000","created":true,"label":"新規✨"}

### Replace an XML document
// @name putCatalog
PUT {{scheme}}://{{host}}/{{version}}/catalog/items/sku-7 HTTP/1.1
Content-Type: application/xml; charset=utf-8
If-Match: "catalog-rev-3"

<?xml version="1.0" encoding="UTF-8"?>
<catalog xmlns="urn:example:catalog" xml:lang="fr">
  <!-- Embedded XML remains balanced across lines. -->
  <item sku="sku-7" available="true">
    <name>Café crème &amp; thé</name>
    <warehouse code="東京">A-12</warehouse>
    <note><![CDATA[Handle with care: <fragile> 🚚]]></note>
  </item>
</catalog>
### XML body closed

HTTP/1.1 204 No Content
ETag: "catalog-rev-4"
X-Unicode-Echo: café-東京-🚚

### GraphQL query with variables and fragments
# @name projectDashboard
POST {{scheme}}://{{host}}/graphql HTTP/1.1
Authorization: Bearer {{token}}
Content-Type: application/graphql
X-Operation-Name: ProjectDashboard

query ProjectDashboard($id: ID!, $withTasks: Boolean! = true) {
  project(id: $id) {
    id
    name
    owner { displayName locale }
    tasks(first: 3) @include(if: $withTasks) {
      nodes { id title status }
      pageInfo { hasNextPage endCursor }
    }
    ...ProjectLabels
  }
}
fragment ProjectLabels on Project {
  labels { name color }
}

### GraphQL mutation
// @name renameProject
POST {{scheme}}://{{host}}/graphql
Content-Type: application/graphql

mutation RenameProject($id: ID!, $name: String!) {
  renameProject(input: {id: $id, name: $name}) {
    project { id name updatedAt }
    errors { field message }
  }
}

HTTP/1.1 200 OK
Content-Type: application/json

{
  "data": {
    "renameProject": {
      "project": {"id": "prj_9000", "name": "北極星 🌟", "updatedAt": "2026-07-12T09:30:00Z"},
      "errors": []
    }
  }
}

### Upload metadata and select a local file variable
# @prompt uploadFile Path to a small fixture document
PATCH {{scheme}}://{{host}}/{{version}}/projects/prj_9000/artifact HTTP/1.1
Authorization: Bearer {{token}}
Content-Type: application/json-patch+json
X-Source-File: {{uploadFile}}

[
  {"op": "replace", "path": "/title", "value": "Résumé 🚀"},
  {"op": "add", "path": "/keywords/-", "value": "解析"},
  {"op": "test", "path": "/revision", "value": 4}
]

HTTP/1.1 422 Unprocessable Entity
Content-Type: application/problem+json

{
  "type": "https://api.example.test/problems/revision-conflict",
  "title": "Revision mismatch",
  "status": 422,
  "detail": "Expected revision 4; found 5.",
  "instance": "/v2/projects/prj_9000/artifact"
}

