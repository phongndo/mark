{# A compact, template-only Jinja fixture: café ☕ and orbit 🚀 #}
{% set title = "Syntax résumé" %}
{% set values = [1, 2.5, -3, 0x2A] %}
Title: {{ title|upper }}
Escaped: {{ "<tag> & café"|e }}
Lookup: {{ user.profile['display-name']|default('anonymous', true) }}
Math: {{ (values[0] + values[1]) * 2 ** 3 // 2 }}
{% if user is defined and user.active and 'admin' in user.roles -%}
Hello, {{- user.name|trim|title -}}!
{% elif values|length >= 3 %}
There are {{ values|length }} values; odd? {{ values|length is odd }}.
{% else %}
Nothing to report.
{% endif %}
{% for key, value in settings|dictsort %}
{{ loop.index }}. {{ key }} = {{ value|pprint }}{% if not loop.last %};{% endif %}
{% else %}
No settings.
{% endfor %}
{% macro badge(label, kind='info') -%}[{{ kind }}: {{ label|e }}]{% if caller is defined %} {{ caller(label) }}{% endif %}{%- endmacro %}
{{ badge('ready 🚀', kind='success') }}
{% call(name) badge(name, 'caller') %}{{ name|upper }}{% endcall %}
{% filter upper|replace('CAFÉ', 'CAFE') %}Mixed café text{% endfilter %}
{% raw %}Literal {{ untouched }} and {% not_a_block %}.{% endraw %}
