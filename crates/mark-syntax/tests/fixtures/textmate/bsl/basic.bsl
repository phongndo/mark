#Область Пример🚀
&НаКлиенте
&проверка(режим = сервер)
Процедура показатьприветствие(Знач имя, момент = '2024-02-29 12:34:56') Экспорт
    Перем текст, флаг Экспорт;
    // Русский комментарий, English note, astral 𐐷.
    Флаг = Истина И НЕ Ложь;
    Текст = "Привет, """ + Имя + """! 🚀";
    Если Флаг И Момент >= '2024-01-01' Тогда
        Сообщить(Текст);
    Иначе
        Message("fallback");
    КонецЕсли;
    Запрос = Новый Запрос;
    Запрос.Текст = "Выбрать Разрешенные
        Товары.Код Как Код,
        Товары.Наименование Как Имя
    Из Справочник.Номенклатура Как Товары
    Где Товары.ПометкаУдаления = Ложь";
КонецПроцедуры

Function EnglishTotal(Val Price, Count = 2) Export
    Result = Round(Price * Count, 2) + StrLen("💡");
    Return Result <> Undefined;
EndFunction
