Процедура подготовитьданные(Знач начало, конец = '2025-12-31 23:59:59') Экспорт
    Перем запрос, таблица, индекс Экспорт;
    Перем заголовок, путь, готово;
    Заголовок = "Отчёт ""Годовой"" 🌍";
    Путь = КаталогВременныхФайлов() + "/данные.json";
    Готово = Истина И НЕ Ложь ИЛИ NULL = Неопределено;
    Индекс = 10 + 4 * 3 / 2 - 1 % 2;
    Если Индекс >= 10 И Индекс <= 99 Тогда
        Сообщить(СтрШаблон("Строка %1", Заголовок));
    ИначеЕсли Готово = Ложь Тогда
        ПоказатьПредупреждение(, "Нет данных");
    Иначе
        Сигнал();
    КонецЕсли;
    Запрос = Новый Запрос;
    Запрос.Текст = "Выбрать Разрешенные Первые 25
        Продажи.Номенклатура Как Номенклатура,
        Сумма(Продажи.Сумма) Как Сумма,
        ""товар 🚀"" Как Метка
    Из
        РегистрНакопления.Продажи.Обороты(&Начало, &Конец) Как Продажи
    // Комментарий внутри текста запроса
    Где
        Продажи.Сумма > 0
        И Продажи.Активность = Истина
    Сгруппировать По
        Продажи.Номенклатура
    Упорядочить По
        Сумма Убыв";
    Запрос.УстановитьПараметр("Начало", Начало);
    Запрос.УстановитьПараметр("Конец", Конец);
    Таблица = Запрос.Выполнить().Выгрузить();
    Для Каждого Строка Из Таблица Цикл
        Если ЗначениеЗаполнено(Строка.Номенклатура) Тогда
            Сообщить(Строка.Номенклатура);
        КонецЕсли;
    КонецЦикла;
    Для Индекс = 1 По Таблица.Количество() Цикл
        Строка = Таблица[Индекс - 1];
        Продолжить;
    КонецЦикла;
    Пока Индекс > 0 Цикл
        Индекс = Индекс - 1;
        Если Индекс = 3 Тогда
            Прервать;
        КонецЕсли;
    КонецЦикла;
    Попытка
        ЗаписатьJSON(Новый ЗаписьJSON, Таблица);
    Исключение
        Сообщить(КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
        ВызватьИсключение ОписаниеОшибки();
    КонецПопытки;
КонецПроцедуры

&AtClient
&Telemetry(Name = Client, Mode=Fast)
Procedure RunClient(Val Caption, When = '2026/01/02 03:04') Export
    Var Answer, Counter, Value Export;
    // English controls and an emoji are intentional 🛰️.
    Answer = True AND NOT False OR Undefined = NULL;
    Counter = 1.5 + 2 * 8 / 4 - 3;
    If Answer AND Counter <> 0 Then
        Message(Upper(TrimAll(Caption)));
    ElsIf Counter < 0 Then
        Status("negative");
    Else
        Beep();
    EndIf;
    Try
        Value = New Structure("Key,Value", "alpha", 42);
    Except
        Raise ErrorDescription();
    EndTry;
    For Each Item In Value Do
        Continue;
    EndDo;
    For Counter = 0 To 3 Do
        Value = Max(Value, Counter);
    EndDo;
    While Counter >= 0 Do
        Counter = Counter - 1;
        Break;
    EndDo;
EndProcedure

