Функция строковыефункции(исходная)
    Локальная = СокрЛП(Исходная);
    Локальная = Лев(Локальная, 3) + Прав(Локальная, 2);
    Локальная = Сред(Локальная, 2, 4);
    Позиция = СтрНайти(ВРег(Локальная), "ТЕСТ");
    Симв = Символ(КодСимвола("Я", 1));
    Части = СтрРазделить(СтрЗаменить(Локальная, "-", "_"), "_");
    Возврат СтрСоединить(Части, ",") + Симв + Позиция;
КонецФункции
