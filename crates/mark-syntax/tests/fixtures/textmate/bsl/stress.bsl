Function MathAndDates(SourceDate)
    NumberValue = Int(12.75) + Round(3.14159, 2);
    NumberValue = Pow(NumberValue, 2) + Sqrt(81) + Sin(0);
    DateValue = BegOfYear(SourceDate);
    DateValue = EndOfMonth(AddMonth(DateValue, 2));
    Parts = Year(DateValue) + Month(DateValue) + Day(DateValue);
    Parts = Parts + Hour(DateValue) + Minute(DateValue) + Second(DateValue);
    Return Boolean(Parts) AND TypeOf(DateValue) = Type("Date");
EndFunction

