Function EnglishBuiltins(Input)
    Clean = StrReplace(TrimAll(Input), "old", "new");
    Count = StrOccurrenceCount(Clean, "new");
    Stamp = CurrentUniversalDateInMilliseconds();
    Temp = TempFilesDir() + GetPathSeparator() + "mark.tmp";
    Encoded = Base64String(Base64Value("8J+agA=="));
    WriteLogEvent("Fixture.English");
    RefreshInterface();
    Return StrTemplate("%1:%2:%3", Clean, Count, Stamp) + Temp + Encoded;
EndFunction

