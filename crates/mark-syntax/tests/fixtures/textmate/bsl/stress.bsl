Function QueryInEnglish(Parameter)
    Query = New Query;
    Query.Text = "SELECT DISTINCT TOP 5
        Catalog.Code AS Code,
        ""astral 𠜎"" AS Label
    FROM Catalog.Products AS Catalog
    // English query comment
    WHERE Catalog.Code = &Parameter";
    Query.SetParameter("Parameter", Parameter);
    Return Query.Execute();
EndFunction

