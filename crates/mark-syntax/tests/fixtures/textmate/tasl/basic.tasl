# Compact TASL schema fixture: café 東京 λ 🚀 𝌆
namespace ex http://example.com/tasl/basic#
namespace schema http://schema.org/
namespace xsd http://www.w3.org/2001/XMLSchema#

type ex:LocalizedText {
  ex:value -> string
  ex:language -> xsd:language
}
type ex:Contact [
  ex:Email <- string
  ex:Homepage <- <>
  ex:None
]

class ex:Person :: {
  ex:name -> ex:LocalizedText
  ex:identifier -> xsd:string
  ex:contact -> ? ex:Contact
  ex:friend -> * ex:Person
}

edge ex:Knows :: ex:Person =/ ex:LocalizedText /=> ex:Person
edge ex:WorksFor :: ex:Person => schema:Organization
