# Mark collaborative editor: development environment
# Hand-written coverage for comments, exports, quoting, escapes, and interpolation.

APP_NAME="Mark Studio"
APP_ENV=development
APP_VERSION=2.7.0-beta.3
export APP_HOST=127.0.0.1
export APP_PORT=4173
APP_ORIGIN=http://${APP_HOST}:${APP_PORT}
PUBLIC_URL=${APP_ORIGIN}/workspace
API_BASE_URL=${APP_ORIGIN}/api/v2
HEALTHCHECK_URL=${API_BASE_URL}/health
EMPTY_VALUE=
EXPLICIT_EMPTY=""
SINGLE_EMPTY=''

# Paths used by the editor and syntax worker
HOME_DIR=${HOME}
WORKSPACE_ROOT="${HOME_DIR}/Projects/mark examples"
CACHE_DIR=${HOME_DIR}/.cache/mark
SOCKET_PATH=/tmp/mark-preview.sock
WINDOWS_FIXTURE='C:\Users\Public\Mark\fixtures'
RELATIVE_FIXTURES=./crates/mark-syntax/tests/fixtures
ASSET_PATH="${WORKSPACE_ROOT}/assets/textmate"
TRAILING_SLASH=/var/lib/mark/

# Database connections and pool policy
DATABASE_URL=postgres://mark_dev:local-pass@localhost:5432/mark_dev
DATABASE_READONLY_URL='postgres://reader:p@ss@db.internal:5432/mark'
SQLITE_URL=file:./state/mark.db?mode=rwc
DB_POOL_MIN=2
DB_POOL_MAX=16
DB_CONNECT_TIMEOUT=5s
DB_STATEMENT_TIMEOUT=1500ms
DB_SSL_MODE=prefer
DB_APPLICATION_NAME="${APP_NAME} worker"

# Redis, queues, and object storage
REDIS_URL=redis://localhost:6379/2
REDIS_PREFIX=mark:${APP_ENV}:
QUEUE_NAME=syntax-analysis
QUEUE_RETRY_LIMIT=7
QUEUE_VISIBILITY_TIMEOUT=45
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=mark-fixtures
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY='local secret with spaces'

# Authentication settings
SESSION_SECRET="dev-only-\"rotate-me\""
JWT_ISSUER=${APP_ORIGIN}
JWT_AUDIENCE=mark-web
JWT_TTL=15m
OAUTH_CLIENT_ID=mark-local
OAUTH_CLIENT_SECRET='literal#$value'
OAUTH_CALLBACK=${PUBLIC_URL}/auth/callback
COOKIE_NAME=mark_session
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Mail and user-facing defaults
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM="Mark Robot <robot@example.test>"
SUPPORT_EMAIL=support@example.test
DEFAULT_LOCALE=en-US
FALLBACK_LOCALES=pt-BR,ja-JP,ar-EG
WELCOME_MESSAGE="Olá, 世界 👋🏽"
JAPANESE_LABEL='共同編集を開始'
ARABIC_LABEL="مرحبًا بالمحرر"
ASTRAL_SAMPLE="rocket 🚀, clef 𝄞, and test tube 🧪"
COMBINING_SAMPLE="Café and naïve Zürich"

# TextMate and rendering options
SYNTAX_ENGINE=textmate
SYNTAX_THEME=mark-night
SYNTAX_WORKERS=4
SYNTAX_TIMEOUT_MS=2500
GRAMMAR_ROOT=${WORKSPACE_ROOT}/assets/grammars
FIXTURE_ROOT=${WORKSPACE_ROOT}/crates/mark-syntax/tests/fixtures
ENABLE_INJECTIONS=true
ENABLE_SEMANTIC_TOKENS=false
TAB_WIDTH=4
INSERT_SPACES=true
FONT_FAMILY="JetBrains Mono"
FONT_FEATURES='liga,zero,ss01'

# Double-quoted escape recognition
ESCAPED_QUOTES="say \"hello\" and \"goodbye\""
ESCAPED_SLASH="one\\two\\three"
ESCAPED_CONTROLS="tab:\t newline:\n return:\r backspace:\b formfeed:\f"
UNICODE_ESCAPE="copyright \u00A9 and snowman \u2603"
UPPER_HEX_ESCAPE="capital omega \u03A9"
LOWER_HEX_TEXT="lowercase digits stay textual: \u03c0"
UNKNOWN_ESCAPE="not-special: \q"
SINGLE_QUOTED_ESCAPES='backslashes \n and \u263A remain literal'

# Expansion forms intentionally exercise greedy interpolation
CURRENT_USER=${USER}
USER_CACHE=${HOME}/.cache/${APP_NAME}
LOG_PATTERN="${APP_ENV}:${APP_VERSION}:${USER}"
DEFAULT_STYLE=${THEME:-night}
REQUIRED_TOKEN=${API_TOKEN:?set API_TOKEN}
NESTED_LOOKING=${OUTER_${INNER}}
ADJACENT_EXPANSIONS=${APP_NAME}${APP_VERSION}
DOLLAR_WITHOUT_BRACES=$HOME/bin
SHELL_COMMAND='$(date) is not interpolation in dotenv syntax'

# Feature gates and percentages
FEATURE_COMMAND_PALETTE=true
FEATURE_MINIMAP=false
FEATURE_INLINE_DIFF=true
FEATURE_REMOTE_GRAMMARS=experimental
FEATURE_FLAGS=syntax,search,review,collaboration
ROLLOUT_PERCENT=25
MAX_OPEN_FILES=512
MAX_FILE_BYTES=10485760
RATE_LIMIT_PER_MINUTE=120
TELEMETRY_SAMPLE_RATE=0.05

 # One leading space is accepted before a dotenv comment.
COLOR_ACCENT=#7f5af0
URL_WITH_FRAGMENT=https://example.test/docs#installation
QUOTED_HASH="value # retained inside the quoted string"
SINGLE_HASH='another # retained value'
INLINE_COMMENT=enabled # operator note for developers
PASSWORD_WITH_HASH='abc#123'
 export EXPORTED_WITH_NOTE=yes # one leading space is accepted

# Key and spacing boundaries accepted by the vendored matcher
lower_case_key=allowed
Mixed_Case_Key=also_allowed
KEY_WITH_DIGITS_2026=ready
export EXPORTED_KEY="export prefix receives its own scope"
PADDED_KEY = padded value
TIGHT=value=with=additional=equals
LEADING_VALUE=   spaces are part of the value
ONE_SPACE_INDENT=recognized assignment
	TAB_INDENTED=recognized too
TWO_SPACE_KEY=the key itself begins with one captured space

# Values resembling other languages remain ordinary dotenv text
JSON_BLOB='{"theme":"night","emoji":"🌙"}'
CSV_COLUMNS=id,name,updated_at
REGEX_TEXT='^[A-Z_][A-Z0-9_]*$'
MARKDOWN_TEXT="**bold** and `code`"
IPV6_LOOPBACK=::1
DURATION_SEQUENCE=1h30m
BOOLEAN_UPPER=TRUE
NULL_WORD=null

# Deployment-shaped values
CONTAINER_IMAGE=registry.example.test/mark/server:${APP_VERSION}
KUBERNETES_NAMESPACE=mark-${APP_ENV}
RELEASE_SHA=8f37c2a
RELEASE_CREATED_AT=2026-07-12T14:03:22Z
OTEL_SERVICE_NAME=mark-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://collector:4318
RUST_LOG=mark=debug,tower_http=info
RUST_BACKTRACE=1
NO_PROXY=localhost,127.0.0.1,::1

	# A tab-indented comment exercises the same grammar branch.
FINAL_INTERPOLATION="${APP_NAME} ${APP_VERSION} 🚀"
FINAL_SINGLE='quotes balanced'
FINAL_PLAIN=ready
