# Local development settings
APP_NAME="Mark Preview"
APP_ENV=development
export APP_PORT=4173
PUBLIC_URL=https://example.test/app
API_URL=${PUBLIC_URL}/api
GREETING="Olá, 世界 👋"
OWNER='D’Arcy'
EMPTY=
SPACED = "value with spaces"
ESCAPED="tab:\t quote:\" slash:\\ smile:\u263A"
LITERAL='${APP_ENV} stays literal'
DATABASE_URL=postgres://mark:secret@localhost:5432/mark
FEATURE_FLAGS=syntax,search,🚀
INLINE_NOTE=enabled # read by local tooling
export CACHE_DIR="${HOME}/.cache/mark"
