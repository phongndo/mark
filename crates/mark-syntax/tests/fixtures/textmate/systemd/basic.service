# Basic worker unit used to exercise common systemd syntax.
; Semicolon comments are accepted alongside number-sign comments.

[Unit]
Description="μ-latency worker 🚀 with a tab\tseparator"
After=network-online.target
StartLimitInterval=30s

[Service]
Type=notify
Environment=PORT=8080 ENABLE_METRICS=yes
Environment='GREETING=hello world' "ESCAPED=line\nnext"
Environment=STATE_DIR=${STATE_DIRECTORY} INSTANCE=$INSTANCE
ExecStartPre=-/usr/bin/install -d -m 0750 /run/worker
ExecStart=@-/usr/bin/worker worker-main \
    "--unit=%n" "--delay=250μs" "--label=launch 🚀"
Restart=on-failure
TimeoutStartSec=1min30s
MemoryMax=1.5G
MemoryHigh=infinity
PrivateTmp=yes
NoNewPrivileges=true
CapabilityBoundingSet=CAP_NET_BIND_SERVICE CAP_CHOWN
ReadOnlyDirectories=/usr /etc

[Install]
WantedBy=multi-user.target
[X-Metadata]
Owner="platform team"
Enabled=no
