    "stoppedEarly": false
  },
  "escapeCatalog": {
    "quotationMark": "\"",
    "reverseSolidus": "\\",
    "solidus": "\/",
    "backspace": "\b",
    "formFeed": "\f",
    "lineFeed": "\n",
    "carriageReturn": "\r",
    "horizontalTab": "\t",
    "basicUnicode": "\u03BB",
    "surrogatePair": "\uD83D\uDE80",
    "literalUnicode": "Καλημέρα · 東京 · café",
    "literalAstral": "🧪 🌌 𝄞"
