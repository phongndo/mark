{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "mark-json-stress",
  "version": "2.7.0-rc.1",
  "description": "Grammar workbench for café, 東京, λ, and 🚀",
  "private": true,
  "application": {
    "id": "syntax-preview",
    "displayName": "Grammar Workbench",
    "release": {
      "channel": "canary",
      "published": true,
      "deprecated": false,
      "sunset": null
    },
    "runtime": {
      "command": "bin/mark --grammar json",
      "workingDirectory": "./fixtures/textmate",
      "environment": {
        "MARK_LOG": "trace",
        "CACHE/STRATEGY": "memory+disk",
        "feature.experimental?": true
      },
      "limits": {
        "workers": 8,
        "timeoutSeconds": 12.75,
        "memoryBytes": 1073741824
      }
    }
  },
  "servers": [
    {
      "name": "primary",
      "url": "https://api.example.test/v1/parse?mode=strict&trace=1",
      "headers": {
        "Accept": "application/json",
        "X-Client/Version": "2026.07"
      },
      "retry": {
        "attempts": 3,
        "backoffSeconds": [
          0.25,
          1,
          4e0
        ]
      }
    },
    {
      "name": "local fallback",
      "url": "http://127.0.0.1:8080/health",
      "headers": {},
      "retry": null
    }
  ],
  "buildGraph": {
    "entrypoints": [
      "src/main.rs",
      "src/engine/tokenizer.rs"
    ],
    "tasks": [
      {
        "id": "compile-grammars",
        "command": "cargo run --bin grammar-compile -- assets/tm-grammars",
        "dependsOn": [],
        "inputs": [
          "assets/tm-grammars/languages/*.json"
        ],
        "outputs": [
          "target/grammars.pack"
        ],
        "cache": true
      },
      {
        "id": "test-parity",
        "command": "cargo test -p mark-syntax --test textmate_golden",
        "dependsOn": [
          "compile-grammars"
        ],
        "inputs": [
          "crates/mark-syntax/tests/fixtures/textmate/**/*.jsonl"
        ],
        "outputs": [],
        "cache": false
      },
      {
        "id": "publish-report",
        "command": "node tools/report.mjs --format=json",
        "dependsOn": [
          "test-parity"
        ],
        "environment": {
          "CI": "true",
          "REPORT_LOCALE": "ja-JP"
        },
        "cache": false
      }
    ]
  },
  "recentRuns": [
    {
      "id": "run_01JZ8T3M9B",
      "state": "passed",
      "startedAt": "2026-07-12T09:14:33.482Z",
