  "numericSamples": [
    0,
    -0,
    17,
    -42,
    0.125,
    -9876.54321,
    6.022e23,
    -1.602176634E-19,
    1e+308,
    9007199254740991,
    18446744073709551615,
    123456789012345678901234567890,
    3.141592653589793238462643383279
  ],
  "workspace": {
    "folders": [
      {
        "uri": "file:///Users/example/Grammar%20Lab",
        "languageIds": [
          "json",
          "jsonc",
          "yaml"
        ]
      }
    ],
    "editor": {
      "tabSize": 2,
      "insertSpaces": true,
      "rulers": [80, 100, 120]
    }
  },
  "grammarPackage": {
    "scopeName": "source.json",
    "fileTypes": ["json", "har", "ipynb"],
    "patterns": [
      {
        "include": "#value"
      },
      {
        "match": "-?(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?(?:[eE][+-]?[0-9]+)?",
        "name": "constant.numeric.json"
      }
    ]
  },
  "odd keys": {
    "": "empty key",
    "with spaces": "preserved",
    "colon:key": "not a delimiter here",
    "comma,key": "still one key",
    "brackets[]{}": "punctuation",
    "quote\"inside": "escaped",
    "back\\slash": "portable"
  },
  "edgeValues": {
    "truth": true,
    "lie": false,
    "missing": null,
    "emptyArray": [],
    "emptyObject": {},
    "escaped": "quote \" slash \\ newline \n tab \t",
    "mixed": "prefix-\u2764-❤️-\uD83E\uDDEA-suffix"
  }
}
