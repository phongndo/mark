@charset "UTF-8"
// Basic Stylus fixture — café, 東京, emoji 😀, astral 𝌆

accent = #3a7
gap = 1.25rem

rounded(radius = 6px)
  border-radius radius
  background rgba(51, 170, 119, .15)

.card[data-state="ready"]
  padding gap
  color accent
  border 1px solid darkgreen
  &:hover
    transform translateY(-2px)
  .title::before
    content "✓ "

@media screen and (min-width: 48rem)
  .card
    width calc(100% - 2 * gap)

