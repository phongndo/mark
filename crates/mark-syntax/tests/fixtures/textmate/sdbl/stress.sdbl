// Comprehensive 1C query fixture.
// BMP characters: Ω, Ж, 中. Astral characters: 😀, 𐐷, 𝄞.
ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ ПЕРВЫЕ 100
    Продажи.Период КАК Период,
    Продажи.Организация КАК Организация,
    Представление(Продажи.Организация) КАК ОрганизацияТекст,
    Продажи.Номенклатура КАК Номенклатура,
    ПредставлениеСсылки(Продажи.Номенклатура) КАК НоменклатураТекст,
    Продажи.Количество КАК Количество,
    Продажи.Сумма КАК Сумма,
    ЕСТЬNULL(Продажи.Скидка, 0) КАК Скидка,
    Продажи.Сумма - ЕСТЬNULL(Продажи.Скидка, 0) КАК СуммаНетто,
    ВЫБОР
        КОГДА Продажи.Сумма >= &КрупнаяСумма ТОГДА "Крупная Ω"
        КОГДА Продажи.Сумма МЕЖДУ &СредняяСумма И &КрупнаяСумма ТОГДА "Средняя 中"
        ИНАЧЕ "Обычная 😀"
    КОНЕЦ КАК Категория,
    ТипЗначения(Продажи.Номенклатура) КАК ТипНоменклатуры
ПОМЕСТИТЬ ВременныеПродажи
ИЗ
    РегистрНакопления.Продажи.Обороты(
        &НачалоПериода,
        &КонецПериода,
        Период,
        Организация В ИЕРАРХИИ (&Организация)
    ) КАК Продажи
ГДЕ
    Продажи.Количество > 0
    И Продажи.Сумма ЕСТЬ НЕ NULL
    И НЕ Продажи.Номенклатура = Неопределено
    И Продажи.Активность = Истина
    ИЛИ Продажи.Комментарий ПОДОБНО &Шаблон СПЕЦСИМВОЛ "~"
ИНДЕКСИРОВАТЬ ПО
    Организация,
    Номенклатура;

////////////////////////////////////////////////////////////////////////////////
// A second temporary table exercises joins, dates, strings, and parameters.
ВЫБРАТЬ
    Остатки.Номенклатура,
    Остатки.Склад,
    Остатки.КоличествоОстаток КАК Остаток,
    Цены.Цена КАК Цена,
    Остатки.КоличествоОстаток * ЕСТЬNULL(Цены.Цена, 0) КАК Стоимость,
    Год(&ДатаОтчета) КАК ГодОтчета,
    Квартал(&ДатаОтчета) КАК КварталОтчета,
    Месяц(&ДатаОтчета) КАК МесяцОтчета,
    ДеньГода(&ДатаОтчета) КАК ДеньГодаОтчета,
    ДеньНедели(&ДатаОтчета) КАК ДеньНеделиОтчета,
    НачалоПериода(&ДатаОтчета, МЕСЯЦ) КАК НачалоМесяца,
    КонецПериода(&ДатаОтчета, МЕСЯЦ) КАК КонецМесяца,
    ДобавитьКДате(&ДатаОтчета, ДЕНЬ, -7) КАК НеделюНазад,
    РазностьДат(&НачалоПериода, &КонецПериода, ДЕНЬ) КАК Дней
ПОМЕСТИТЬ ОстаткиСЦенами
ИЗ
    РегистрНакопления.ТоварыНаСкладах.Остатки(&ДатаОтчета) КАК Остатки
        ЛЕВОЕ ВНЕШНЕЕ СОЕДИНЕНИЕ РегистрСведений.Цены.СрезПоследних(
            &ДатаОтчета,
            ВидЦены = &ВидЦены
        ) КАК Цены
        ПО Остатки.Номенклатура = Цены.Номенклатура
ГДЕ
    Остатки.Склад В (&Склад1, &Склад2)
    И Остатки.КоличествоОстаток <> 0;

////////////////////////////////////////////////////////////////////////////////
// String function family, including escaped quotes and explicit Unicode.
ВЫБРАТЬ
    Клиенты.Ссылка,
    СокрЛП(Клиенты.Наименование) КАК ЧистоеИмя,
    НРег(Клиенты.Наименование) КАК НижнийРегистр,
    ВРег(Клиенты.Наименование) КАК ВерхнийРегистр,
    Лев(Клиенты.Наименование, 3) КАК ПервыеТри,
    Прав(Клиенты.Код, 4) КАК ПоследниеЧетыре,
    Подстрока(Клиенты.Наименование, 2, 10) КАК Фрагмент,
    ДлинаСтроки(Клиенты.Наименование) КАК Длина,
    СтрНайти(Клиенты.Наименование, "ООО") КАК Позиция,
    СтрЗаменить(Клиенты.Комментарий, """", "'") КАК БезКавычек,
    "BMP Ω Ж 中; astral 😀 𐐷 𝄞" КАК Юникод,
    "Первая строка
вторая строка полностью закрытой строки" КАК МногострочныйТекст
ПОМЕСТИТЬ НормализованныеКлиенты
ИЗ
    Справочник.Контрагенты КАК Клиенты
ГДЕ
    Клиенты.Наименование НЕ ПОДОБНО "Тест%"
    И Клиенты.ИНН ЕСТЬ НЕ NULL;

////////////////////////////////////////////////////////////////////////////////
// Numeric, conversion, special, and aggregate functions.
ВЫБРАТЬ
    ВременныеПродажи.Организация,
    КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВременныеПродажи.Номенклатура) КАК Позиций,
    СУММА(ВременныеПродажи.Количество) КАК ВсегоКоличество,
    СРЕДНЕЕ(ВременныеПродажи.СуммаНетто) КАК СреднийЧек,
    МИНИМУМ(ВременныеПродажи.СуммаНетто) КАК МинимальныйЧек,
    МАКСИМУМ(ВременныеПродажи.СуммаНетто) КАК МаксимальныйЧек,
    Окр(СРЕДНЕЕ(ВременныеПродажи.СуммаНетто), 2) КАК ОкругленныйЧек,
    Цел(МАКСИМУМ(ВременныеПродажи.Количество)) КАК ЦелоеКоличество,
    SQRT(МАКСИМУМ(ВременныеПродажи.СуммаНетто)) КАК Корень,
    POW(2, 8) КАК Степень,
    LOG10(1000) КАК Логарифм,
    ВЫРАЗИТЬ(СРЕДНЕЕ(ВременныеПродажи.СуммаНетто) КАК ЧИСЛО(15, 2)) КАК ЧекЧислом,
    UUID() КАК Идентификатор,
    РазмерХранимыхДанных(ВременныеПродажи.Организация) КАК Размер
ИЗ
    ВременныеПродажи КАК ВременныеПродажи
СГРУППИРОВАТЬ ПО
    ВременныеПродажи.Организация
ИМЕЮЩИЕ
    СУММА(ВременныеПродажи.СуммаНетто) > &Порог
УПОРЯДОЧИТЬ ПО
    МаксимальныйЧек УБЫВ;

////////////////////////////////////////////////////////////////////////////////
// CASE, constants, types, and English aliases accepted by the grammar.
SELECT
    CASE
        WHEN Source.Enabled = True AND Source.Value IS NOT NULL THEN "active"
        WHEN Source.Enabled = False OR Source.Value = Undefined THEN "inactive"
        ELSE "unknown"
    END AS State,
    Cast(Source.Value AS Number(12, 3)) AS NumericValue,
    Cast(Source.Caption AS String(80)) AS TextValue,
    Cast(Source.Moment AS Date) AS DateValue,
    Cast(Source.Enabled AS Boolean) AS BooleanValue,
    Value(Catalog.Products.EmptyRef) AS EmptyProduct,
    Type("String") AS DeclaredType,
    DateTime(2025, 3, 31, 23, 59, 59) AS BuiltAt,
    IsNULL(Source.Caption, "say ""hello"" 𐐷") AS SafeCaption
INTO EnglishSample
FROM
    ExternalDataSource.Items AS Source
WHERE
    Source.Value BETWEEN 1.5 AND 99.75
    AND Source.Kind IN (&KindA, &KindB)
    AND Source.Owner REFS Catalog.Partners
    AND Source.Caption LIKE &EnglishPattern ESCAPE "~"
ORDER BY
    State ASC,
    NumericValue DESC;

////////////////////////////////////////////////////////////////////////////////
// Grouping sets, union, hierarchy, totals, and ordering controls.
ВЫБРАТЬ
    Данные.Организация,
    Данные.Категория,
    СУММА(Данные.СуммаНетто) КАК Оборот
ИЗ
    ВременныеПродажи КАК Данные
СГРУППИРОВАТЬ ПО ГРУППИРУЮЩИМ НАБОРАМ
    ((Данные.Организация, Данные.Категория),
     (Данные.Организация),
     ())

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
    &РезервнаяОрганизация,
    "Резерв",
    0
ИЗ
    ПустаяТаблица.Значения КАК Пусто
ИТОГИ
    СУММА(Оборот)
ПО ОБЩИЕ,
    Организация
АВТОУПОРЯДОЧИВАНИЕ;

////////////////////////////////////////////////////////////////////////////////
// More date and trigonometric aliases in one focused projection.
ВЫБРАТЬ
    Полугодие(&ДатаОтчета) КАК Полугодие,
    Декада(&ДатаОтчета) КАК Декада,
    Неделя(&ДатаОтчета) КАК Неделя,
    Час(&Момент) КАК Час,
    Минута(&Момент) КАК Минута,
    Секунда(&Момент) КАК Секунда,
    ACOS(0.5) КАК Арккосинус,
    ASIN(0.5) КАК Арксинус,
    ATAN(1) КАК Арктангенс,
    COS(0) + SIN(0) + TAN(0) КАК Тригонометрия,
    EXP(1) КАК Экспонента
ИЗ
    ПараметрыСеанса КАК Параметры;

////////////////////////////////////////////////////////////////////////////////
// Join variants and update clause.
SELECT
    A.Key,
    B.Caption,
    C.Total
FROM
    TableA AS A
        INNER JOIN TableB AS B ON A.Key = B.Key
        RIGHT OUTER JOIN TableC AS C ON B.Key = C.Key
        FULL OUTER JOIN TableD AS D ON C.Key = D.Key
WHERE
    A.Key IN HIERARCHY (&Root)
FOR UPDATE OF
    A.Key;

УНИЧТОЖИТЬ ВременныеПродажи;
УНИЧТОЖИТЬ ОстаткиСЦенами;
УНИЧТОЖИТЬ НормализованныеКлиенты;
DROP EnglishSample;

// Final line proves comment state closes at end of line: Ω 中 😀
