// Compact 1C query; BMP: Ω Ж 中, astral: 😀 𐐷
ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 10
    Товары.Ссылка КАК Товар,
    Представление(Товары.Ссылка) КАК Имя,
    ВЫБОР
        КОГДА Товары.Остаток > &Минимум ТОГДА Истина
        ИНАЧЕ Ложь
    КОНЕЦ КАК Доступен,
    "Метка Ω 中 😀" КАК Примечание
ИЗ
    Справочник.Товары КАК Товары
ГДЕ
    Товары.Наименование ПОДОБНО &Шаблон
    И Товары.ПометкаУдаления = Ложь
УПОРЯДОЧИТЬ ПО
    Имя ВОЗР;

// English aliases and an escaped quote
SELECT "say ""hello"" 𐐷" AS Caption, DateTime(2025, 3, 31) AS Stamp
FROM Catalog.Products AS Products;
