@comment{Compact BibTeX grammar tour — café 東京 🚀 𝌆}
Free-form comment text remains a comment until the next at-sign.
@preamble{"Generated for " # lab # { — λ bibliography}}
@string{lab = "Orbital Research Lab"}
@string(monthx = jan # " / " # {März})

@book{knuth-2026,
  author = "Donald E. Knuth and Ada Lovelace",
  title = {Braced {nested {deep}} title — café 🚀},
  year = 2026,
  month = monthx # " " # 7,
  publisher = lab,
  note = "Quoted {group {inside}} with 東京 and 𝌆"
}
Ordinary bibliography commentary between two entries.
@article(turing:orbit,
  author = {Alan Turing and Emmy Noether},
  title = prefix # "Concatenated" # { {Signals} λ},
  journal = "Journal of {Orbital} Computing",
  number = 42,
  pages = {1--19},
  year = 2027,
  note = {Parenthesized entry with {nested braces} 🚀}
)
