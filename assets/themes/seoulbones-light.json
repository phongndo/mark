{
  "name": "Seoulbones Light",
  "type": "light",
  "colors": {
    "editor.background": "#E2E2E2",
    "editor.foreground": "#555555",
    "editorCursor.foreground": "#555555",
    "editor.lineHighlightBackground": "#DADADA",
    "editor.findMatchBackground": "#CBB1CA",
    "statusBar.background": "#C4C4C4",
    "diffEditor.insertedLineBackground": "#AEDEAE",
    "diffEditor.removedLineBackground": "#E5CBD1",
    "gitDecoration.addedResourceForeground": "#628562",
    "gitDecoration.deletedResourceForeground": "#DC5284",
    "gitDecoration.modifiedResourceForeground": "#0084A3"
  },
  "tokenColors": [
    {
      "name": "Vim Comment",
      "scope": [
        "comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#628562"
      }
    },
    {
      "name": "Vim Constant",
      "scope": [
        "constant",
        "variable.other.constant"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#7C7C7C"
      }
    },
    {
      "name": "Vim Boolean",
      "scope": [
        "constant.language.boolean"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#555555"
      }
    },
    {
      "name": "Vim String",
      "scope": [
        "string"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#4A7587"
      }
    },
    {
      "name": "Vim Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#896500"
      }
    },
    {
      "name": "Vim Identifier",
      "scope": [
        "variable",
        "support.variable"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#555555"
      }
    },
    {
      "name": "Vim Function",
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#6C6B20"
      }
    },
    {
      "name": "Vim Statement",
      "scope": [
        "keyword",
        "storage",
        "keyword.operator"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#0084A3"
      }
    },
    {
      "name": "Vim PreProc",
      "scope": [
        "meta.preprocessor",
        "keyword.control.import"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#BE6A84"
      }
    },
    {
      "name": "Vim Type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#6D4C52"
      }
    },
    {
      "name": "Vim Special",
      "scope": [
        "constant.character.escape",
        "support.constant",
        "support.type.property-name"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#755F74"
      }
    },
    {
      "name": "Vim Delimiter",
      "scope": [
        "punctuation"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#7C7C7C"
      }
    },
    {
      "name": "Vim Added",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#628562"
      }
    },
    {
      "name": "Vim Removed",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#DC5284"
      }
    },
    {
      "name": "Vim Changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#0084A3"
      }
    }
  ],
  "markSource": {
    "repository": "https://github.com/zenbones-theme/zenbones.nvim",
    "commit": "8304d8df9b823ff11e103afa62f38c39f534abe6",
    "path": "colors/seoulbones.vim",
    "background": "light"
  }
}
