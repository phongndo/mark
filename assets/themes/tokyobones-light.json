{
  "name": "Tokyobones Light",
  "type": "light",
  "colors": {
    "editor.background": "#D6D7DC",
    "editor.foreground": "#333A57",
    "editorCursor.foreground": "#333A57",
    "editor.lineHighlightBackground": "#CDCED4",
    "editor.findMatchBackground": "#B3A9C9",
    "statusBar.background": "#B9BBC3",
    "diffEditor.insertedLineBackground": "#A9CEC7",
    "diffEditor.removedLineBackground": "#DFBEC3",
    "gitDecoration.addedResourceForeground": "#34645D",
    "gitDecoration.deletedResourceForeground": "#8B4351",
    "gitDecoration.modifiedResourceForeground": "#34548C"
  },
  "tokenColors": [
    {
      "name": "Vim Comment",
      "scope": [
        "comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#7C7E89"
      }
    },
    {
      "name": "Vim Constant",
      "scope": [
        "constant",
        "variable.other.constant"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#5B6694"
      }
    },
    {
      "name": "Vim Boolean",
      "scope": [
        "constant.language.boolean"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#333A57"
      }
    },
    {
      "name": "Vim String",
      "scope": [
        "string"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#5B6694"
      }
    },
    {
      "name": "Vim Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#176775"
      }
    },
    {
      "name": "Vim Identifier",
      "scope": [
        "variable",
        "support.variable"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#4A537A"
      }
    },
    {
      "name": "Vim Function",
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#333A57"
      }
    },
    {
      "name": "Vim Statement",
      "scope": [
        "keyword",
        "storage",
        "keyword.operator"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#5A4A79"
      }
    },
    {
      "name": "Vim PreProc",
      "scope": [
        "meta.preprocessor",
        "keyword.control.import"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#5A4A79"
      }
    },
    {
      "name": "Vim Type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#484F6B"
      }
    },
    {
      "name": "Vim Special",
      "scope": [
        "constant.character.escape",
        "support.constant",
        "support.type.property-name"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#34548C"
      }
    },
    {
      "name": "Vim Delimiter",
      "scope": [
        "punctuation"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#737686"
      }
    },
    {
      "name": "Vim Added",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#34645D"
      }
    },
    {
      "name": "Vim Removed",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#8B4351"
      }
    },
    {
      "name": "Vim Changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#34548C"
      }
    }
  ],
  "markSource": {
    "repository": "https://github.com/zenbones-theme/zenbones.nvim",
    "commit": "8304d8df9b823ff11e103afa62f38c39f534abe6",
    "path": "colors/tokyobones.vim",
    "background": "light"
  }
}
