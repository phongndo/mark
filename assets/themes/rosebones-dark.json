{
  "name": "Rosebones Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#1A1825",
    "editor.foreground": "#E1D4D4",
    "editorCursor.foreground": "#E7DDDD",
    "editor.lineHighlightBackground": "#222030",
    "editor.findMatchBackground": "#673592",
    "statusBar.background": "#312E43",
    "diffEditor.insertedLineBackground": "#1D2C34",
    "diffEditor.removedLineBackground": "#3D2229",
    "gitDecoration.addedResourceForeground": "#317490",
    "gitDecoration.deletedResourceForeground": "#EB7193",
    "gitDecoration.modifiedResourceForeground": "#9CCFD8"
  },
  "tokenColors": [
    {
      "name": "Vim Comment",
      "scope": [
        "comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#69657E"
      }
    },
    {
      "name": "Vim Constant",
      "scope": [
        "constant",
        "variable.other.constant"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#BC9493"
      }
    },
    {
      "name": "Vim Boolean",
      "scope": [
        "constant.language.boolean"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#E1D4D4"
      }
    },
    {
      "name": "Vim String",
      "scope": [
        "string"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#BC9493"
      }
    },
    {
      "name": "Vim Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#BC9493"
      }
    },
    {
      "name": "Vim Identifier",
      "scope": [
        "variable",
        "support.variable"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#CAB0AF"
      }
    },
    {
      "name": "Vim Function",
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#E1D4D4"
      }
    },
    {
      "name": "Vim Statement",
      "scope": [
        "keyword",
        "storage",
        "keyword.operator"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#317490"
      }
    },
    {
      "name": "Vim PreProc",
      "scope": [
        "meta.preprocessor",
        "keyword.control.import"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#317490"
      }
    },
    {
      "name": "Vim Type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#DFDEF1"
      }
    },
    {
      "name": "Vim Special",
      "scope": [
        "constant.character.escape",
        "support.constant",
        "support.type.property-name"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#9CCFD8"
      }
    },
    {
      "name": "Vim Delimiter",
      "scope": [
        "punctuation"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#7D7997"
      }
    },
    {
      "name": "Vim Added",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#317490"
      }
    },
    {
      "name": "Vim Removed",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#EB7193"
      }
    },
    {
      "name": "Vim Changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#9CCFD8"
      }
    }
  ],
  "markSource": {
    "repository": "https://github.com/zenbones-theme/zenbones.nvim",
    "commit": "8304d8df9b823ff11e103afa62f38c39f534abe6",
    "path": "colors/rosebones.vim",
    "background": "dark"
  }
}
