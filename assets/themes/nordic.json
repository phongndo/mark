      "scope": [
        "keyword",
        "storage"
      ],
      "settings": {
        "foreground": "#D08770",
        "fontStyle": ""
      }
    },
    {
      "name": "Vim Operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#BBC3D4",
        "fontStyle": ""
      }
    },
    {
      "name": "Vim Preprocessor",
      "scope": [
        "meta.preprocessor",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#BF616A",
        "fontStyle": ""
      }
    },
    {
      "name": "Vim Type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#EBCB8B",
        "fontStyle": ""
      }
