#!/usr/bin/env sh
set -eu

repo_dir=$(CDPATH= cd "$(dirname "$0")/.." && pwd)

if [ ! -t 1 ]; then
  echo "error: this smoke test must run in an interactive terminal" >&2
  exit 1
fi

cargo build -p mark-cli

tmp_dir=$(mktemp -d)
cleanup() {
  rm -rf "$tmp_dir"
}
trap cleanup EXIT INT TERM

config_home="$tmp_dir/config"
mkdir -p "$config_home/mark"
cat > "$config_home/mark/config.toml" <<'TOML'
# Intentionally invalid values for the interactive error-pane smoke test.
addition_fg = "octarine"

[keymap.global]
edit_hunk = "ctrl-nope"
TOML

fixture_repo="$tmp_dir/repo"
mkdir -p "$fixture_repo/src"
git -C "$fixture_repo" init -q
git -C "$fixture_repo" config user.email mark-test@example.invalid
git -C "$fixture_repo" config user.name "mark test"

cat > "$fixture_repo/src/example.rs" <<'RS'
pub fn answer() -> usize {
    41
}
RS
git -C "$fixture_repo" add src/example.rs
git -C "$fixture_repo" commit -q -m initial

cat > "$fixture_repo/src/example.rs" <<'RS'
pub fn answer() -> usize {
    42
}

pub fn label() -> &'static str {
    "error pane smoke test"
}
RS

cat <<EOF

Launching mark against a temporary repo with an intentionally invalid isolated config.

Example error-log cases:
  On launch              invalid color/keymap config should open the error pane
  Ctrl-Shift-C           copy the full error pane text to the terminal clipboard
  Esc                    close the error pane; Esc should NOT quit mark
  Ctrl-G                 open editor for focused hunk; EDITOR is intentionally invalid, so an error pane should open
  o, Down, Enter
                         toggle disabled Live reload; --no-watch should open an error pane
  rm -rf "$fixture_repo/.git", then press r
                         reload failure should open an error pane

Try this in the TUI:
  + / -    resize the error pane; you can also drag the red separator line
  f        file filter; bottom bar should show @query
  /        grep; bottom bar should show /query and right-aligned match count
  n / p    move between grep match lines
  q        quit

Temporary repo: $fixture_repo
Temporary config: $config_home/mark/config.toml

EOF

XDG_CONFIG_HOME="$config_home" \
VISUAL="$tmp_dir/definitely-missing-editor" \
GIT_EDITOR="$tmp_dir/definitely-missing-editor" \
EDITOR="$tmp_dir/definitely-missing-editor" \
  "$repo_dir/target/debug/mark" diff --repo "$fixture_repo" --no-watch --no-syntax
