#!/usr/bin/env sh
set -eu

version="${1:-latest}"
install_dir="$(mktemp -d)"
script_dir="$(CDPATH= cd "$(dirname "$0")" && pwd)"
installer="${MARK_INSTALLER:-$script_dir/install.sh}"
# Set MARK_INSTALLER_URL to smoke a published installer instead of this checkout.

cleanup() {
  rm -rf "$install_dir"
}
trap cleanup EXIT INT TERM

if [ -n "${MARK_INSTALLER_URL:-}" ]; then
  installer="$install_dir/install.sh"
  curl -fsSL "$MARK_INSTALLER_URL" -o "$installer"
fi

MARK_INSTALL_DIR="$install_dir" MARK_VERSION="$version" sh "$installer"
test -x "$install_dir/mark"
"$install_dir/mark" --version
