#!/usr/bin/env sh
set -eu

version="${1:-latest}"
repo_dir="$(CDPATH= cd "$(dirname "$0")/.." && pwd)"
install_dir="$(mktemp -d)"

cleanup() {
  rm -rf "$install_dir"
}
trap cleanup EXIT INT TERM

cd "$repo_dir"
cargo build -p mark-cli --locked

install -m 755 "$repo_dir/target/debug/mark" "$install_dir/mark"

"$install_dir/mark" update --target-version "$version" --install-dir "$install_dir"
test -x "$install_dir/mark"
"$install_dir/mark" --version
