#!/usr/bin/env sh
set -eu

if [ "$#" -lt 3 ] || [ "$#" -gt 4 ]; then
  echo "usage: scripts/ci/package-dist <release-tag> <target> <binary> [revision]" >&2
  exit 2
fi

tag="$1"
target="$2"
binary="$3"
revision="${4:-}"
dist_dir="${MARK_DIST_DIR:-dist}"

case "$tag" in
  v | *[!A-Za-z0-9._-]* | [!v]*)
    echo "package-dist: invalid release tag: $tag" >&2
    exit 2
    ;;
  v*) ;;
esac
case "$target" in
  *[!A-Za-z0-9._-]* | "")
    echo "package-dist: invalid target: $target" >&2
    exit 2
    ;;
esac

if [ ! -x "$binary" ]; then
  echo "package-dist: binary is not executable: $binary" >&2
  exit 1
fi

package="mark-${tag}-${target}"
asset="${package}.tar.gz"
package_dir="$dist_dir/$package"

rm -rf "$package_dir"
mkdir -p "$package_dir"
install -m 755 "$binary" "$package_dir/mark"
cp README.md LICENSE "$package_dir/"
notices="$package_dir/THIRD_PARTY_NOTICES"
: > "$notices"
for notice_dir in assets/grammars/licenses assets/themes/licenses; do
  for notice in "$notice_dir"/*; do
    [ -f "$notice" ] || continue
    notice_name="${notice##*/}"
    {
      printf '%s\n' '================================================================================'
      printf '%s\n' "$notice_name"
      printf '%s\n\n' '================================================================================'
      cat "$notice"
      printf '\n\n'
    } >> "$notices"
  done
done
if [ -n "$revision" ]; then
  printf '%s\n' "$revision" > "$package_dir/REVISION"
fi

tar -czf "$dist_dir/$asset" -C "$dist_dir" "$package"
if command -v shasum >/dev/null 2>&1; then
  (cd "$dist_dir" && shasum -a 256 "$asset" > "$asset.sha256")
elif command -v sha256sum >/dev/null 2>&1; then
  (cd "$dist_dir" && sha256sum "$asset" > "$asset.sha256")
else
  echo "package-dist: missing shasum or sha256sum" >&2
  exit 1
fi

if [ -n "${GITHUB_OUTPUT:-}" ]; then
  printf 'asset=%s\nchecksum=%s\n' \
    "$dist_dir/$asset" "$dist_dir/$asset.sha256" >> "$GITHUB_OUTPUT"
fi
printf '%s\n' "$dist_dir/$asset"
